\contentsline {table}{\numberline {5.1}{\ignorespaces BS=1 landmark-inference latency across all available device/backend variants. This table isolates only the landmark model forward pass, so it explains whether the model itself is the bottleneck; lower is better. Bold marks the best value in each row.}}{23}{table.caption.12}%
\contentsline {table}{\numberline {5.2}{\ignorespaces BS=1 mobile-only XNNPACK landmark-inference latency; lower latency is better. Bold marks the lowest latency in each row.}}{24}{table.caption.14}%
\contentsline {table}{\numberline {5.3}{\ignorespaces Redmi BS=1 XNNPACK landmark latency and accuracy. LM inf. means landmark inference and ms means milliseconds. Bold values mark the lower latency and lower error within each model pair.}}{26}{table.caption.17}%
\contentsline {table}{\numberline {5.4}{\ignorespaces Redmi batch scaling in landmark-inference latency. LM means landmark inference and BS means batch size. Bold marks the lowest latency in each batch-size column.}}{26}{table.caption.20}%
\contentsline {table}{\numberline {5.5}{\ignorespaces Three-device INT8 XNNPACK batch scaling for PFLD-MNv2-1.0 in landmark-inference latency; lower is better. Bold marks the best value in each batch-size column.}}{28}{table.caption.21}%
\contentsline {table}{\numberline {5.6}{\ignorespaces Three-device INT8 XNNPACK batch scaling for PipNet-R18 in landmark-inference latency; lower is better. Bold marks the best value in each batch-size column.}}{28}{table.caption.22}%
\contentsline {table}{\numberline {5.7}{\ignorespaces BS=1 PC INT8 and Redmi INT8 landmark-inference latency. Bold marks the lower latency in each row.}}{29}{table.caption.26}%
