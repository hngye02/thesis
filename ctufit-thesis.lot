\contentsline {table}{\numberline {5.1}{\ignorespaces Landmark-inference latency at BS=1 across all available device/backend variants. Values are milliseconds and isolate only the landmark model forward pass; lower is better. Bold marks the lowest latency for each model.}}{25}{table.caption.12}%
\contentsline {table}{\numberline {5.2}{\ignorespaces Landmark-inference latency at BS=1 for mobile-only XNNPACK runs; lower latency is better. Bold marks the lowest latency in each row.}}{26}{table.caption.14}%
\contentsline {table}{\numberline {5.3}{\ignorespaces Landmark latency and accuracy on Redmi at BS=1 with XNNPACK. LM inf. means landmark inference and ms means milliseconds. Bold text values mark the lower latency and lower error within each model pair.}}{28}{table.caption.17}%
\contentsline {table}{\numberline {5.4}{\ignorespaces Per-image landmark-inference latency batch scaling on Redmi. LM means landmark inference and BS means batch size. Values are total batch latency divided by BS. Bold marks the lowest latency in each batch-size column.}}{29}{table.caption.20}%
\contentsline {table}{\numberline {5.5}{\ignorespaces Per-image landmark-inference latency batch scaling for PFLD-MNv2-1.0 with INT8 XNNPACK across three devices. Values are total batch latency divided by BS; lower is better. Bold marks the best value in each batch-size column.}}{31}{table.caption.21}%
\contentsline {table}{\numberline {5.6}{\ignorespaces Per-image landmark-inference latency batch scaling for PipNet-R18 with INT8 XNNPACK across three devices. Values are total batch latency divided by BS; lower is better. Bold marks the best value in each batch-size column.}}{31}{table.caption.22}%
\contentsline {table}{\numberline {5.7}{\ignorespaces Landmark-inference latency at BS=1 for PC INT8 and Redmi INT8. Bold marks the lower latency in each row.}}{32}{table.caption.26}%
\contentsline {table}{\numberline {5.8}{\ignorespaces Landmark-inference latency on iPhone 14 at BS=1 by backend. XNN means XNNPACK. Bold marks the lowest latency in each row.}}{36}{table.caption.28}%
\contentsline {table}{\numberline {5.9}{\ignorespaces Per-image landmark-inference latency batch scaling on iPhone 14. LM means landmark inference and BS means batch size. Values are total batch latency divided by BS. Bold marks the lowest latency in each batch-size column.}}{37}{table.caption.31}%
\contentsline {table}{\numberline {5.10}{\ignorespaces Landmark-inference latency at BS=1 for PC INT8 and iPhone 14 INT8. Bold marks the lower latency in each row.}}{38}{table.caption.32}%
